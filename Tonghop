-- Delta Roblox Script - Hamster Menu (Sửa triệt để lỗi viền vuông của Menu & Nút)
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- 1. Tạo ScreenGui (Đảm bảo hiển thị trên cùng mọi giao diện game)
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "HamsterGlowMenuGui"
screenGui.ResetOnSpawn = false
screenGui.DisplayOrder = 999999 
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.Parent = PlayerGui

-- 2. TẠO FRAME VIỀN MENU (Đóng vai trò làm viền màu cam nhấp nháy)
local menuBorder = Instance.new("Frame")
menuBorder.Name = "MenuBorder"
menuBorder.Size = UDim2.new(0.4, 0, 0.5, 0)
menuBorder.Position = UDim2.new(0.3, 0, 0.25, 0)
menuBorder.BackgroundColor3 = Color3.fromRGB(180, 60, 0) -- Màu cam đậm ban đầu
menuBorder.BorderSizePixel = 0
menuBorder.Active = true
menuBorder.Draggable = true -- Cho phép kéo thả từ khung viền này
menuBorder.Parent = screenGui

local uiSizeConstraint = Instance.new("UISizeConstraint")
uiSizeConstraint.MinSize = Vector2.new(300, 220)
uiSizeConstraint.MaxSize = Vector2.new(500, 380)
uiSizeConstraint.Parent = menuBorder

-- Bo góc cho khung viền ngoài của Menu
local borderCorner = Instance.new("UICorner")
borderCorner.CornerRadius = UDim.new(0, 12)
borderCorner.Parent = menuBorder

-- 3. TẠO FRAME NỀN MENU CHÍNH (Nằm thụt vào trong 1px để lộ viền cam)
local mainFrame = Instance.new("Frame")
mainFrame.Name = "MainFrame"
mainFrame.Size = UDim2.new(1, -2, 1, -2) -- Nhỏ hơn viền ngoài 1px mỗi bên (tổng cộng 2px)
mainFrame.Position = UDim2.new(0, 1, 0, 1) -- Căn lề thụt vào đúng 1px
mainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20) -- Nền đen của menu
mainFrame.BorderSizePixel = 0
mainFrame.Parent = menuBorder

-- Bo góc cho Frame nền trong (Nhỏ hơn 1 chút để khít hoàn hảo)
local mainCorner = Instance.new("UICorner")
mainCorner.CornerRadius = UDim.new(0, 11)
mainCorner.Parent = mainFrame

-- Tween đổi màu liên tục từ cam đậm sang cam nhạt cho viền Menu chính
local darkOrange = Color3.fromRGB(180, 60, 0)
local lightOrange = Color3.fromRGB(255, 165, 0)
local tweenInfoMenu = TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
local menuColorTween = TweenService:Create(menuBorder, tweenInfoMenu, {BackgroundColor3 = lightOrange})
menuColorTween:Play()

-- 4. Tiêu đề "Hamster"
local titleLabel = Instance.new("TextLabel")
titleLabel.Name = "TitleLabel"
titleLabel.Size = UDim2.new(1, 0, 0.15, 0)
titleLabel.BackgroundTransparency = 1
titleLabel.Text = "Hamster"
titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
titleLabel.Font = Enum.Font.GothamBold
titleLabel.TextScaled = true
titleLabel.Parent = mainFrame

-- Line phân cách bên trong
local line = Instance.new("Frame")
line.Size = UDim2.new(0.9, 0, 0, 1)
line.Position = UDim2.new(0.05, 0, 0.15, 0)
line.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
line.BorderSizePixel = 0
line.Parent = mainFrame

-- 5. Khung cuộn nội dung (ScrollingFrame)
local scrollFrame = Instance.new("ScrollingFrame")
scrollFrame.Name = "ContentScroll"
scrollFrame.Position = UDim2.new(0.05, 0, 0.18, 0)
scrollFrame.Size = UDim2.new(0.9, 0, 0.77, 0)
scrollFrame.BackgroundTransparency = 1
scrollFrame.BorderSizePixel = 0
scrollFrame.ScrollBarThickness = 4
scrollFrame.ScrollBarImageColor3 = Color3.fromRGB(255, 165, 0)
