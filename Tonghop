local uiListLayout = Instance.new("UIListLayout")
uiListLayout.SortOrder = Enum.SortOrder.LayoutOrder
uiListLayout.Padding = UDim.new(0, 10)
uiListLayout.Parent = scrollFrame

local uiPadding = Instance.new("UIPadding")
uiPadding.PaddingTop = UDim.new(0, 6)
uiPadding.PaddingBottom = UDim.new(0, 6)
uiPadding.PaddingLeft = UDim.new(0, 6)
uiPadding.PaddingRight = UDim.new(0, 6)
uiPadding.Parent = scrollFrame


-- HÀM TẠO NÚT SIÊU CHUẨN (KHÔNG BỊ LỖI VIỀN VUÔNG)
local function createPerfectButton(name, text, textColor, borderStartColor, borderEndColor, onClickFunction)
    -- Frame ngoài: Đóng vai trò là "Viền màu" có bo góc tròn trịa
    local borderFrame = Instance.new("Frame")
    borderFrame.Name = name.."_Border"
    borderFrame.Size = UDim2.new(0.98, 0, 0, 45)
    borderFrame.BackgroundColor3 = borderStartColor
    borderFrame.BorderSizePixel = 0
    borderFrame.Parent = scrollFrame

    local buttonCorner = Instance.new("UICorner")
    buttonCorner.CornerRadius = UDim.new(0, 8)
    buttonCorner.Parent = borderFrame

    -- Frame trong: Đóng vai trò làm "Nền Đen", nhỏ hơn frame ngoài 1px mỗi bên để lộ phần viền màu ra
    local innerFrame = Instance.new("Frame")
    innerFrame.Name = "Inner"
    innerFrame.Size = UDim2.new(1, -2, 1, -2)
    innerFrame.Position = UDim2.new(0, 1, 0, 1)
    innerFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- Nền đen chuẩn
    innerFrame.BorderSizePixel = 0
    innerFrame.Parent = borderFrame

    local innerCorner = Instance.new("UICorner")
    innerCorner.CornerRadius = UDim.new(0, 7) -- Bo góc nhỏ hơn 1 chút để khít
    innerCorner.Parent = innerFrame

    -- Nút bấm chính nằm đè lên hoàn toàn
    local actualButton = Instance.new("TextButton")
    actualButton.Name = "Button"
    actualButton.Size = UDim2.new(1, 0, 1, 0)
    actualButton.BackgroundTransparency = 1 -- Trong suốt hoàn toàn để lộ thiết kế bên dưới
    actualButton.Text = text
    actualButton.TextColor3 = textColor
    actualButton.Font = Enum.Font.GothamBold
    actualButton.TextSize = 16
    actualButton.Parent = innerFrame

    -- Hiệu ứng chuyển màu viền liên tục (Thay đổi màu của borderFrame)
    local tweenInfo = TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
    local colorTween = TweenService:Create(borderFrame, tweenInfo, {BackgroundColor3 = borderEndColor})
    colorTween:Play()

    -- Kết nối sự kiện click
    actualButton.MouseButton1Click:Connect(onClickFunction)
end


